{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex.local/schemas/repository-manifest.schema.json",
  "title": "Document Processor Repository Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "repositoryManifestId",
    "repositoryName",
    "repositoryPurpose",
    "generatedAt",
    "canonicalLayer",
    "modelVersion",
    "domainProfiles",
    "sourcePackageCount",
    "sourcePackages",
    "chunkCount",
    "exports",
    "retrievalEvaluation"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "repositoryManifestId": {
      "type": "string",
      "minLength": 1
    },
    "repositoryName": {
      "type": "string",
      "minLength": 1
    },
    "repositoryPurpose": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "canonicalLayer": {
      "type": "string",
      "const": "source-index"
    },
    "modelVersion": {
      "type": "string",
      "minLength": 1
    },
    "domainProfiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/domainProfile"
      }
    },
    "sourcePackageCount": {
      "type": "integer",
      "minimum": 1
    },
    "sourcePackages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sourcePackage"
      }
    },
    "chunkCount": {
      "type": "integer",
      "minimum": 1
    },
    "exports": {
      "$ref": "#/$defs/exports"
    },
    "retrievalEvaluation": {
      "$ref": "#/$defs/retrievalEvaluation"
    },
    "notes": {
      "type": "string"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "domainProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domainId",
        "profileName",
        "profilePath"
      ],
      "properties": {
        "domainId": {
          "type": "string",
          "minLength": 1
        },
        "profileName": {
          "type": "string",
          "minLength": 1
        },
        "profilePath": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "sourcePackage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceIndexId",
        "sourceId",
        "sourceTitle",
        "sourceFamilyId",
        "documentType",
        "sourceStatus",
        "pageRange",
        "chunkCount",
        "reviewBatchIds",
        "sourceIndexPath",
        "markdownPath",
        "reviewIndexPath",
        "selfReviewPath"
      ],
      "properties": {
        "sourceIndexId": {
          "type": "string",
          "minLength": 1
        },
        "classification": {
          "type": "object",
          "additionalProperties": true
        },
        "sourceId": {
          "type": "string",
          "minLength": 1
        },
        "sourceTitle": {
          "type": "string",
          "minLength": 1
        },
        "sourceFamilyId": {
          "type": "string",
          "minLength": 1
        },
        "documentType": {
          "type": "string",
          "minLength": 1
        },
        "sourceStatus": {
          "type": "string",
          "minLength": 1
        },
        "sourceReference": {
          "type": "string"
        },
        "sourceVersionId": {
          "type": "string"
        },
        "jurisdiction": {
          "type": [
            "string",
            "null"
          ]
        },
        "authorityLevel": {
          "type": "string"
        },
        "pageRange": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "start",
            "end"
          ],
          "properties": {
            "start": {
              "type": "integer",
              "minimum": 1
            },
            "end": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "chunkCount": {
          "type": "integer",
          "minimum": 1
        },
        "reviewBatchIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "sourceIndexPath": {
          "type": "string",
          "minLength": 1
        },
        "markdownPath": {
          "type": "string",
          "minLength": 1
        },
        "reviewIndexPath": {
          "type": "string",
          "minLength": 1
        },
        "selfReviewPath": {
          "type": "string",
          "minLength": 1
        },
        "textLayerQuality": {
          "type": "string",
          "enum": [
            "clean",
            "mixed",
            "noisy",
            "unknown"
          ]
        },
        "pageImageBackstop": {
          "type": "boolean"
        },
        "lineReferencesAvailable": {
          "type": "boolean"
        },
        "relationships": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relationship"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "exports": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "jsonlPath",
        "csvPath",
        "repositoryManifestPath"
      ],
      "properties": {
        "repositoryManifestPath": {
          "type": "string",
          "minLength": 1
        },
        "exportManifestPath": {
          "type": "string",
          "minLength": 1
        },
        "jsonlPath": {
          "type": "string",
          "minLength": 1
        },
        "csvPath": {
          "type": "string",
          "minLength": 1
        },
        "retrievalQuestionsPath": {
          "type": "string",
          "minLength": 1
        },
        "retrievalResultsPath": {
          "type": "string",
          "minLength": 1
        },
        "retrievalEvaluationPath": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "retrievalEvaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evaluationId",
        "method",
        "queryCount",
        "top1HitCount",
        "top3Coverage"
      ],
      "properties": {
        "evaluationId": {
          "type": "string",
          "minLength": 1
        },
        "method": {
          "type": "string",
          "minLength": 1
        },
        "queryCount": {
          "type": "integer",
          "minimum": 0
        },
        "top1HitCount": {
          "type": "integer",
          "minimum": 0
        },
        "top3Coverage": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "relationship": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relationType"
      ],
      "properties": {
        "relationType": {
          "type": "string",
          "enum": [
            "references",
            "implements",
            "interprets",
            "amends",
            "supersedes",
            "reprints",
            "companion_guidance",
            "duplicate_or_reprint",
            "jurisdictional_modification",
            "related_methodology",
            "follows",
            "precedes",
            "supports",
            "boundary_of",
            "cross_references",
            "same_source"
          ]
        },
        "targetSourceId": {
          "type": "string",
          "minLength": 1
        },
        "targetChunkId": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      },
      "anyOf": [
        {
          "required": [
            "targetSourceId"
          ]
        },
        {
          "required": [
            "targetChunkId"
          ]
        }
      ]
    }
  }
}
