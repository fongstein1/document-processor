{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex.local/schemas/document-classification.schema.json",
  "title": "Document Classification Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "documentClassificationId",
    "sourceId",
    "sourceFamilyId",
    "domainId",
    "documentType",
    "purpose",
    "intendedAudience",
    "authoritySourceType",
    "confidentiality",
    "recommendedProfile",
    "recommendedChunkingStrategy",
    "confidence",
    "unresolvedQuestions"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "documentClassificationId": {
      "type": "string",
      "minLength": 1
    },
    "sourceId": {
      "type": "string",
      "minLength": 1
    },
    "sourceFamilyId": {
      "type": "string",
      "minLength": 1
    },
    "domainId": {
      "type": "string",
      "minLength": 1
    },
    "subdomainId": {
      "type": [
        "string",
        "null"
      ]
    },
    "documentType": {
      "type": "string",
      "minLength": 1
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "intendedAudience": {
      "type": "string",
      "minLength": 1
    },
    "authoritySourceType": {
      "type": "string",
      "minLength": 1
    },
    "confidentiality": {
      "type": "string",
      "minLength": 1
    },
    "publicationDate": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "effectiveDate": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "version": {
      "type": [
        "string",
        "null"
      ]
    },
    "approvalStatus": {
      "type": [
        "string",
        "null"
      ]
    },
    "language": {
      "type": [
        "string",
        "null"
      ]
    },
    "recommendedProfile": {
      "type": "string",
      "minLength": 1
    },
    "recommendedChunkingStrategy": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "unresolvedQuestions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
