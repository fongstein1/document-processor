{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex.local/schemas/extraction-output.schema.json",
  "title": "Document Processor Extraction Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "extractionRunId",
    "batchId",
    "generatedAt",
    "processingStatus",
    "extractionMethod",
    "sourceGroups"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "extractionRunId": {
      "type": "string",
      "minLength": 1
    },
    "batchId": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "processingStatus": {
      "type": "string",
      "enum": [
        "draft",
        "extracted",
        "review_pending",
        "blocked",
        "complete"
      ]
    },
    "extractionMethod": {
      "type": "string",
      "minLength": 1
    },
    "sourceGroups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sourceGroup"
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": true
    },
    "notes": {
      "type": "string"
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "sourceGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceId",
        "filename",
        "filePath",
        "sourceFamilyId",
        "domainId",
        "documentType",
        "processingStatus",
        "extractedItems"
      ],
      "properties": {
        "sourceId": {
          "type": "string",
          "minLength": 1
        },
        "filename": {
          "type": "string",
          "minLength": 1
        },
        "filePath": {
          "type": "string",
          "minLength": 1
        },
        "sourceFamilyId": {
          "type": "string",
          "minLength": 1
        },
        "domainId": {
          "type": "string",
          "minLength": 1
        },
        "documentType": {
          "type": "string",
          "minLength": 1
        },
        "sourceTitle": {
          "type": "string"
        },
        "sourceReference": {
          "type": [
            "string",
            "null"
          ]
        },
        "versionDate": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "pageCount": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "processingStatus": {
          "type": "string",
          "enum": [
            "selected",
            "extracted",
            "review_pending",
            "blocked",
            "error"
          ]
        },
        "notes": {
          "type": "string"
        },
        "extractedItems": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/extractedItem"
          }
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "citation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "citationText"
      ],
      "properties": {
        "citationText": {
          "type": "string",
          "minLength": 1
        },
        "pageReference": {
          "type": "string"
        },
        "sectionReference": {
          "type": "string"
        },
        "sourceReference": {
          "type": "string"
        },
        "lineReference": {
          "type": "string"
        },
        "pageStart": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "pageEnd": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        }
      }
    },
    "extractedItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stableId",
        "extractedItemId",
        "itemKind",
        "sourceId",
        "sourceFamilyId",
        "domainId",
        "documentType",
        "chunkText",
        "summary",
        "keywords",
        "citations",
        "confidence",
        "reviewFlags",
        "learnerFacingEligible",
        "appReadyEligible",
        "nonLearnerFacingNotes"
      ],
      "properties": {
        "stableId": {
          "type": "string",
          "minLength": 1
        },
        "extractedItemId": {
          "type": "string",
          "minLength": 1
        },
        "itemKind": {
          "type": "string",
          "enum": [
            "chunk",
            "table",
            "definition",
            "summary_candidate",
            "glossary_candidate",
            "review_note"
          ]
        },
        "sourceId": {
          "type": "string",
          "minLength": 1
        },
        "sourceFamilyId": {
          "type": "string",
          "minLength": 1
        },
        "domainId": {
          "type": "string",
          "minLength": 1
        },
        "documentType": {
          "type": "string",
          "minLength": 1
        },
        "sourceTitle": {
          "type": "string"
        },
        "sourceReference": {
          "type": [
            "string",
            "null"
          ]
        },
        "sourcePath": {
          "type": "string"
        },
        "pageReference": {
          "type": "string"
        },
        "sectionReference": {
          "type": "string"
        },
        "chunkText": {
          "type": "string",
          "minLength": 1
        },
        "normalizedText": {
          "type": "string"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "citations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/citation"
          }
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "reviewFlags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reviewStatus": {
          "type": "string",
          "enum": [
            "draft_candidate",
            "needs_human_review",
            "reviewed",
            "approved_for_export",
            "approved_for_learning",
            "rejected"
          ]
        },
        "learnerFacingEligible": {
          "type": "boolean"
        },
        "appReadyEligible": {
          "type": "boolean"
        },
        "nonLearnerFacingNotes": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
